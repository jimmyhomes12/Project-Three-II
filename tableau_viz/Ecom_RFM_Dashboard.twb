<!-- build 20253.26.0206.0336                               -->
<workbook original-version='18.1' source-build='2025.3.3 (20253.26.0206.0336)' source-platform='win' version='18.1' xmlns:user='http://www.tableausoftware.com/xml/user'>
  <document-format-change-manifest>
    <AnimationOnByDefault />
    <MarkAnimation />
    <ObjectModelEncapsulateLegacy />
    <ObjectModelExtractV2 />
    <ObjectModelTableType />
    <SchemaViewerObjectModel />
    <SheetIdentifierTracking />
    <_.fcp.VConnDownstreamExtractsWithWarnings.true...VConnDownstreamExtractsWithWarnings />
    <WindowsPersistSimpleIdentifiers />
  </document-format-change-manifest>
  <preferences>
    <preference name='ui.encoding.shelf.height' value='24' />
    <preference name='ui.shelf.height' value='26' />
  </preferences>
  <datasources>
    <datasource caption='rfm_scores (Multiple Connections)' inline='true' name='federated.rfm_dashboard' version='18.1'>
      <connection class='federated'>
        <named-connections>
          <named-connection caption='rfm_scores' name='textscan.rfm_scores'>
            <connection class='textclean' cleaning='yes' compat='no' csvFile='../data/rfm_scores.csv' dataRefreshTime='' directory='../data' filename='' interpretationMode='8' password='' server='' validate='no' />
          </named-connection>
          <named-connection caption='full_ecom' name='textscan.full_ecom'>
            <connection class='textclean' cleaning='yes' compat='no' csvFile='../data/full_ecom.csv' dataRefreshTime='' directory='../data' filename='' interpretationMode='8' password='' server='' validate='no' />
          </named-connection>
        </named-connections>
        <relation connection='textscan.rfm_scores' name='rfm_scores.csv' table='[rfm_scores#csv$]' type='table'>
          <columns character-set='UTF-8' gridOrigin='A1:G798:no:A1:G798:1' header='yes' locale='en_US' separator=','>
            <column datatype='string' name='customer_id' ordinal='0' />
            <column datatype='integer' name='r_score' ordinal='1' />
            <column datatype='integer' name='f_score' ordinal='2' />
            <column datatype='integer' name='m_score' ordinal='3' />
            <column datatype='real' name='recency_days' ordinal='4' />
            <column datatype='integer' name='frequency' ordinal='5' />
            <column datatype='real' name='total_revenue' ordinal='6' />
          </columns>
        </relation>
        <metadata-records>
          <metadata-record class='capability'>
            <remote-name />
            <remote-type>0</remote-type>
            <parent-name>[rfm_scores.csv]</parent-name>
            <remote-alias />
            <aggregation>Count</aggregation>
            <contains-null>true</contains-null>
            <attributes>
              <attribute datatype='integer' name='context'>0</attribute>
              <attribute datatype='string' name='gridOrigin'>&quot;A1:G798:no:A1:G798:1&quot;</attribute>
              <attribute datatype='integer' name='lost'>0</attribute>
              <attribute datatype='integer' name='outcome'>1</attribute>
              <attribute datatype='integer' name='processed'>797</attribute>
            </attributes>
          </metadata-record>
          <metadata-record class='column'>
            <remote-name>customer_id</remote-name>
            <remote-type>129</remote-type>
            <local-name>[customer_id]</local-name>
            <parent-name>[rfm_scores.csv]</parent-name>
            <remote-alias>customer_id</remote-alias>
            <ordinal>0</ordinal>
            <local-type>string</local-type>
            <aggregation>Count</aggregation>
            <contains-null>true</contains-null>
            <attributes>
              <attribute datatype='string' name='DebugRemoteType'>&quot;CHAR&quot;</attribute>
            </attributes>
            <object-id>[rfm_scores_OBJ]</object-id>
          </metadata-record>
          <metadata-record class='column'>
            <remote-name>r_score</remote-name>
            <remote-type>20</remote-type>
            <local-name>[r_score]</local-name>
            <parent-name>[rfm_scores.csv]</parent-name>
            <remote-alias>r_score</remote-alias>
            <ordinal>1</ordinal>
            <local-type>integer</local-type>
            <aggregation>Sum</aggregation>
            <contains-null>true</contains-null>
            <attributes>
              <attribute datatype='string' name='DebugRemoteType'>&quot;I8&quot;</attribute>
            </attributes>
            <object-id>[rfm_scores_OBJ]</object-id>
          </metadata-record>
          <metadata-record class='column'>
            <remote-name>f_score</remote-name>
            <remote-type>20</remote-type>
            <local-name>[f_score]</local-name>
            <parent-name>[rfm_scores.csv]</parent-name>
            <remote-alias>f_score</remote-alias>
            <ordinal>2</ordinal>
            <local-type>integer</local-type>
            <aggregation>Sum</aggregation>
            <contains-null>true</contains-null>
            <attributes>
              <attribute datatype='string' name='DebugRemoteType'>&quot;I8&quot;</attribute>
            </attributes>
            <object-id>[rfm_scores_OBJ]</object-id>
          </metadata-record>
          <metadata-record class='column'>
            <remote-name>m_score</remote-name>
            <remote-type>20</remote-type>
            <local-name>[m_score]</local-name>
            <parent-name>[rfm_scores.csv]</parent-name>
            <remote-alias>m_score</remote-alias>
            <ordinal>3</ordinal>
            <local-type>integer</local-type>
            <aggregation>Sum</aggregation>
            <contains-null>true</contains-null>
            <attributes>
              <attribute datatype='string' name='DebugRemoteType'>&quot;I8&quot;</attribute>
            </attributes>
            <object-id>[rfm_scores_OBJ]</object-id>
          </metadata-record>
          <metadata-record class='column'>
            <remote-name>recency_days</remote-name>
            <remote-type>5</remote-type>
            <local-name>[recency_days]</local-name>
            <parent-name>[rfm_scores.csv]</parent-name>
            <remote-alias>recency_days</remote-alias>
            <ordinal>4</ordinal>
            <local-type>real</local-type>
            <aggregation>Sum</aggregation>
            <contains-null>true</contains-null>
            <attributes>
              <attribute datatype='string' name='DebugRemoteType'>&quot;R8&quot;</attribute>
            </attributes>
            <object-id>[rfm_scores_OBJ]</object-id>
          </metadata-record>
          <metadata-record class='column'>
            <remote-name>frequency</remote-name>
            <remote-type>20</remote-type>
            <local-name>[frequency]</local-name>
            <parent-name>[rfm_scores.csv]</parent-name>
            <remote-alias>frequency</remote-alias>
            <ordinal>5</ordinal>
            <local-type>integer</local-type>
            <aggregation>Sum</aggregation>
            <contains-null>true</contains-null>
            <attributes>
              <attribute datatype='string' name='DebugRemoteType'>&quot;I8&quot;</attribute>
            </attributes>
            <object-id>[rfm_scores_OBJ]</object-id>
          </metadata-record>
          <metadata-record class='column'>
            <remote-name>total_revenue</remote-name>
            <remote-type>5</remote-type>
            <local-name>[total_revenue]</local-name>
            <parent-name>[rfm_scores.csv]</parent-name>
            <remote-alias>total_revenue</remote-alias>
            <ordinal>6</ordinal>
            <local-type>real</local-type>
            <aggregation>Sum</aggregation>
            <contains-null>true</contains-null>
            <attributes>
              <attribute datatype='string' name='DebugRemoteType'>&quot;R8&quot;</attribute>
