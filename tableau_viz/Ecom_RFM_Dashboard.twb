            <object-id>[rfm_scores_OBJ]</object-id>
          </metadata-record>
        </metadata-records>
      </connection>
      <aliases enabled='yes' />
      <!-- Table objects in the logical model -->
      <column caption='rfm_scores' datatype='table' name='[__tableau_internal_object_id__].[rfm_scores_OBJ]' role='measure' type='quantitative' />
      <column caption='full_ecom' datatype='table' name='[__tableau_internal_object_id__].[full_ecom_OBJ]' role='measure' type='quantitative' />
      <!-- rfm_scores logical columns -->
      <column caption='Customer ID' datatype='string' name='[rfm_scores_OBJ].[customer_id]' role='dimension' type='nominal' />
      <column caption='R Score' datatype='integer' default-format='d' name='[rfm_scores_OBJ].[r_score]' role='dimension' type='ordinal' />
      <column caption='F Score' datatype='integer' default-format='d' name='[rfm_scores_OBJ].[f_score]' role='dimension' type='ordinal' />
      <column caption='M Score' datatype='integer' default-format='d' name='[rfm_scores_OBJ].[m_score]' role='dimension' type='ordinal' />
      <column caption='Recency Days' datatype='real' name='[rfm_scores_OBJ].[recency_days]' role='measure' type='quantitative' />
      <column caption='Frequency' datatype='integer' name='[rfm_scores_OBJ].[frequency]' role='measure' type='quantitative' />
      <column caption='Total Revenue' datatype='real' default-format='$#,##0.00' name='[rfm_scores_OBJ].[total_revenue]' role='measure' type='quantitative' />
      <!-- full_ecom logical columns -->
      <column caption='Customer ID (Transactions)' datatype='string' name='[full_ecom_OBJ].[customer_id]' role='dimension' type='nominal' />
      <column caption='Order ID' datatype='integer' name='[full_ecom_OBJ].[order_id]' role='dimension' type='nominal' />
      <column caption='Category' datatype='string' name='[full_ecom_OBJ].[category]' role='dimension' type='nominal' />
      <column caption='Sales Amount' datatype='real' default-format='$#,##0.00' name='[full_ecom_OBJ].[sales_amount]' role='measure' type='quantitative' />
      <column caption='Order Date' datatype='date' name='[full_ecom_OBJ].[order_date]' role='dimension' type='ordinal' />
      <column caption='Device' datatype='string' name='[full_ecom_OBJ].[device]' role='dimension' type='nominal' />
      <column caption='Promo Code' datatype='string' name='[full_ecom_OBJ].[promo_code]' role='dimension' type='nominal' />
      <column caption='Review Score' datatype='integer' name='[full_ecom_OBJ].[review_score]' role='measure' type='quantitative' />
      <!-- Calculated field: Count Distinct customers -->
      <column caption='Customer Count' datatype='integer' name='[Calculation_CustomerCount]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([rfm_scores_OBJ].[customer_id])' />
      </column>
      <!-- Calculated field: SUM(total_revenue) for heatmap color -->
      <column caption='Total Revenue (Heatmap)' datatype='real' default-format='$#,##0.00' name='[Calculation_RevenueColor]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([rfm_scores_OBJ].[total_revenue])' />
      </column>
      <layout dim-ordering='alphabetic' measure-ordering='alphabetic' show-structure='true' />
      <semantic-values>
        <semantic-value key='[Country].[Name]' value='&quot;United States&quot;' />
      </semantic-values>
      <!-- Logical model: two-table relationship on customer_id -->
      <object-graph>
        <objects>
          <object caption='rfm_scores' id='rfm_scores_OBJ'>
            <properties context=''>
              <relation connection='textscan.rfm_scores' name='rfm_scores.csv' table='[rfm_scores#csv$]' type='table'>
                <columns character-set='UTF-8' gridOrigin='A1:G798:no:A1:G798:1' header='yes' locale='en_US' separator=','>
                  <column datatype='string' name='customer_id' ordinal='0' />
                  <column datatype='integer' name='r_score' ordinal='1' />
                  <column datatype='integer' name='f_score' ordinal='2' />
                  <column datatype='integer' name='m_score' ordinal='3' />
                  <column datatype='real' name='recency_days' ordinal='4' />
                  <column datatype='integer' name='frequency' ordinal='5' />
                  <column datatype='real' name='total_revenue' ordinal='6' />
                </columns>
              </relation>
            </properties>
          </object>
          <object caption='full_ecom' id='full_ecom_OBJ'>
            <properties context=''>
              <relation connection='textscan.full_ecom' name='full_ecom.csv' table='[full_ecom#csv$]' type='table'>
                <columns character-set='UTF-8' gridOrigin='A1:H5001:no:A1:H5001:1' header='yes' locale='en_US' separator=','>
                  <column datatype='integer' name='order_id' ordinal='0' />
                  <column datatype='string' name='customer_id' ordinal='1' />
                  <column datatype='string' name='category' ordinal='2' />
                  <column datatype='real' name='sales_amount' ordinal='3' />
                  <column datatype='date' name='order_date' ordinal='4' />
                  <column datatype='string' name='device' ordinal='5' />
                  <column datatype='string' name='promo_code' ordinal='6' />
                  <column datatype='integer' name='review_score' ordinal='7' />
                </columns>
              </relation>
            </properties>
          </object>
        </objects>
        <!-- Relationship: rfm_scores ↔ full_ecom on customer_id (many-to-many) -->
        <relationships>
          <relationship>
            <expression op='='>
              <expression column='[rfm_scores_OBJ].[customer_id]' />
              <expression column='[full_ecom_OBJ].[customer_id]' />
            </expression>
          </relationship>
        </relationships>
      </object-graph>
    </datasource>
  </datasources>
  <worksheets>
    <!-- ═══════════════════════════════════════════════════════
         Sheet 1: RFM Heatmap
         Rows: R Score (discrete), Cols: F Score (discrete)
         Color: COUNTD(customer_id), Mark: Square
         ═══════════════════════════════════════════════════════ -->
    <worksheet name='RFM Heatmap'>
      <table>
        <view>
          <datasources>
            <datasource caption='rfm_scores (Multiple Connections)' name='federated.rfm_dashboard' />
          </datasources>
          <datasource-dependencies datasource='federated.rfm_dashboard'>
            <column datatype='integer' name='[rfm_scores_OBJ].[r_score]' role='dimension' type='ordinal' />
            <column datatype='integer' name='[rfm_scores_OBJ].[f_score]' role='dimension' type='ordinal' />
            <column datatype='real' name='[rfm_scores_OBJ].[total_revenue]' role='measure' type='quantitative' />
            <column caption='Total Revenue (Heatmap)' datatype='real' default-format='$#,##0.00' name='[Calculation_RevenueColor]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([rfm_scores_OBJ].[total_revenue])' />
            </column>
          </datasource-dependencies>
          <aggregation value='true' />
        </view>
        <style />
        <panes>
          <pane selection-relaxation-option='selection-relaxation-allow'>
            <view>
              <breakdown value='auto' />
            </view>
            <mark class='Square' />
            <encodings>
              <color column='[federated.rfm_dashboard].[Calculation_RevenueColor]' />
            </encodings>
          </pane>
        </panes>
        <rows>[rfm_scores_OBJ].[r_score]</rows>
        <cols>[rfm_scores_OBJ].[f_score]</cols>
      </table>
      <simple-id uuid='{B1C2D3E4-F5A6-7890-B1C2-D3E4F5A67890}' />
    </worksheet>
    <!-- ═══════════════════════════════════════════════════════
         Sheet 2: Sales Trend
         Cols: MONTH(order_date) continuous, Rows: SUM(sales_amount)
         Mark: Line; Filters: category, device
         ═══════════════════════════════════════════════════════ -->
    <worksheet name='Sales Trend'>
      <table>
        <view>
          <datasources>
            <datasource caption='rfm_scores (Multiple Connections)' name='federated.rfm_dashboard' />
          </datasources>
          <datasource-dependencies datasource='federated.rfm_dashboard'>
            <column datatype='date' name='[full_ecom_OBJ].[order_date]' role='dimension' type='ordinal' />
            <column datatype='real' name='[full_ecom_OBJ].[sales_amount]' role='measure' type='quantitative' />
            <column datatype='string' name='[full_ecom_OBJ].[category]' role='dimension' type='nominal' />
            <column datatype='string' name='[full_ecom_OBJ].[device]' role='dimension' type='nominal' />
          </datasource-dependencies>
          <aggregation value='true' />
        </view>
        <style />
        <panes>
          <pane selection-relaxation-option='selection-relaxation-allow'>
            <view>
              <breakdown value='auto' />
            </view>
            <mark class='Line' />
          </pane>
        </panes>
        <rows>SUM([full_ecom_OBJ].[sales_amount])</rows>
        <cols>MONTH([full_ecom_OBJ].[order_date])</cols>
        <filter class='categorical' column='[full_ecom_OBJ].[category]'>
          <groupfilter function='all' user:ui-domain='relevant' user:ui-enumeration='exclusive' user:ui-marker='enumerate' />
        </filter>
        <filter class='categorical' column='[full_ecom_OBJ].[device]'>
          <groupfilter function='all' user:ui-domain='relevant' user:ui-enumeration='exclusive' user:ui-marker='enumerate' />
        </filter>
      </table>
      <simple-id uuid='{C2D3E4F5-A6B7-8901-C2D3-E4F5A6B78901}' />
    </worksheet>
    <!-- ═══════════════════════════════════════════════════════
         Sheet 3: KPI Cards
         Text marks: Customer Count (COUNTD) + Revenue (SUM)
         ═══════════════════════════════════════════════════════ -->
    <worksheet name='KPI Cards'>
      <table>
        <view>
          <datasources>
            <datasource caption='rfm_scores (Multiple Connections)' name='federated.rfm_dashboard' />
          </datasources>
          <datasource-dependencies datasource='federated.rfm_dashboard'>
            <column datatype='string' name='[rfm_scores_OBJ].[customer_id]' role='dimension' type='nominal' />
            <column datatype='real' name='[full_ecom_OBJ].[sales_amount]' role='measure' type='quantitative' />
            <column caption='Customer Count' datatype='integer' name='[Calculation_CustomerCount]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='COUNTD([rfm_scores_OBJ].[customer_id])' />
            </column>
          </datasource-dependencies>
          <aggregation value='true' />
        </view>
        <style />
        <panes>
          <pane selection-relaxation-option='selection-relaxation-allow'>
            <view>
              <breakdown value='auto' />
            </view>
            <mark class='Text' />
            <encodings>
              <text column='[federated.rfm_dashboard].[Calculation_CustomerCount]' />
              <detail column='[federated.rfm_dashboard].[sum:full_ecom_OBJ.sales_amount:ok]' />
            </encodings>
          </pane>
        </panes>
        <rows />
        <cols />
      </table>
      <simple-id uuid='{D3E4F5A6-B7C8-9012-D3E4-F5A6B7C89012}' />
    </worksheet>
  </worksheets>
  <!-- ═══════════════════════════════════════════════════════
       Dashboard: 2025 E-com RFM Dashboard
       Contains RFM Heatmap + Sales Trend + KPI Cards
       Category/Device filters applied to all sheets
       Filter action: clicking heatmap cell filters trend + KPIs
       ═══════════════════════════════════════════════════════ -->
  <dashboards>
    <dashboard name='2025 E-com RFM Dashboard'>
      <size maxheight='768' maxwidth='1366' minheight='768' minwidth='1366' />
      <zones>
        <zone h='98000' id='1' type='layout-basic' w='98000' x='1000' y='1000'>
          <zone h='60000' id='2' type='layout-flow' w='98000' x='1000' y='1000'>
            <zone h='60000' id='3' name='RFM Heatmap' param='RFM Heatmap' type='view' w='48000' x='1000' y='1000' />
            <zone h='60000' id='4' name='Sales Trend' param='Sales Trend' type='view' w='49000' x='50000' y='1000' />
          </zone>
          <zone h='12000' id='5' name='KPI Cards' param='KPI Cards' type='view' w='98000' x='1000' y='62000' />
        </zone>
      </zones>
      <devicelayouts />
      <!-- Filter action: clicking heatmap cell filters Sales Trend and KPI Cards -->
      <actions>
        <action caption='Filter from RFM Heatmap' name='filter_heatmap_to_trend'>
          <trigger type='select' />
          <hover-timeout>0</hover-timeout>
          <filter-commands>
            <filter-command cascase='auto' source-datasource='federated.rfm_dashboard' source-sheet='RFM Heatmap' target-datasource='federated.rfm_dashboard' target-sheet='Sales Trend' />
            <filter-command cascase='auto' source-datasource='federated.rfm_dashboard' source-sheet='RFM Heatmap' target-datasource='federated.rfm_dashboard' target-sheet='KPI Cards' />
          </filter-commands>
        </action>
      </actions>
    </dashboard>
  </dashboards>
  <windows saved-dpi-scale-factor='1.25' source-height='37'>
    <window class='worksheet' maximized='true' name='RFM Heatmap'>
      <cards>
